# =============================================
# CENTRAL DATA API - Environment Configuration
# =============================================

APP_NAME="Central Data API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
APP_TIMEZONE=America/Bogota
APP_LOCALE=es

# Database (MySQL 8)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=central_data_api
DB_USERNAME=centraluser
DB_PASSWORD=secret

# Redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Queue
QUEUE_CONNECTION=database

# Cache & Session
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Telescope (disable in production)
TELESCOPE_ENABLED=true

# Swagger
L5_SWAGGER_CONST_HOST=http://localhost:8001/api

# Client secret for token issuance (CHANGE IN PRODUCTION)
CLIENT_SECRET_SALT=123456789

# Rate limiting defaults
API_RATE_LIMIT_DEFAULT=60

# CORS (configure for your frontends)
CORS_ALLOWED_ORIGINS=*
